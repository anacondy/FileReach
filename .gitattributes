# Normalize line endings: LF in the repo, native on checkout.
* text=auto eol=lf

# Windows batch files must keep CRLF to run reliably.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.icns  binary
*.zip   binary
*.db    binary
